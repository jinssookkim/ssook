# 5. 사후 검정 (Tukey HSD) - 어떤 클러스터 간 차이인지
# ─────────────────────────────────────────
try:
    from statsmodels.stats.multicomp import pairwise_tukeyhsd

    print("=" * 55)
    print("  [5단계] 사후 검정 (Tukey HSD)")
    print("  어떤 클러스터 쌍이 유의미하게 다른지 확인")
    print("=" * 55)

    for feat in features:
        print(f"\n  📌 변수: {feat}")
        tukey = pairwise_tukeyhsd(agg_df[feat], agg_df['cluster'], alpha=0.05)
        result_df = pd.DataFrame(data=tukey._results_table.data[1:],
                                  columns=tukey._results_table.data[0])
        # 유의미한 쌍만 출력
        sig_pairs = result_df[result_df['reject'] == True]
        if len(sig_pairs) == 0:
            print("    → 유의미한 차이를 보이는 클러스터 쌍 없음")
        else:
            for _, row in sig_pairs.iterrows():
                print(f"    클러스터 {int(row['group1'])} vs {int(row['group2'])}: "
                      f"평균차이={float(row['meandiff']):.2f}, p={float(row['p-adj']):.4f} ✅")

except ImportError:
    print("  ℹ️  사후 검정은 statsmodels 설치 후 사용 가능:")
    print("     pip install statsmodels")


