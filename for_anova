# ─────────────────────────────────────────
# 4. ANOVA + Effect Size (eta-squared)
# ─────────────────────────────────────────
def eta_squared(groups):
    """eta-squared 계산 (effect size)"""
    all_data = np.concatenate(groups)
    grand_mean = np.mean(all_data)
    ss_between = sum(len(g) * (np.mean(g) - grand_mean) ** 2 for g in groups)
    ss_total = sum((x - grand_mean) ** 2 for x in all_data)
    return ss_between / ss_total if ss_total != 0 else 0

def interpret_eta(eta):
    if eta >= 0.14:
        return "🔴 큰 효과"
    elif eta >= 0.06:
        return "🟡 중간 효과"
    elif eta >= 0.01:
        return "🟢 작은 효과"
    else:
        return "⚪ 효과 없음"

def interpret_p(p):
    if p < 0.001:
        return "***"
    elif p < 0.01:
        return "** "
    elif p < 0.05:
        return "*  "
    else:
        return "n.s"

print("=" * 55)
print("  [4단계] ANOVA 분석 결과")
print("  ⚠️  K-means 특성상 p값은 거의 유의하게 나옴")
print("      → eta-squared(효과 크기)를 함께 확인하세요")
print("=" * 55)
print(f"  {'변수':<12} {'F값':>8} {'p값':>10} {'유의':>5} {'η²':>8} {'효과크기'}")
print("  " + "-" * 53)

anova_results = []
for feat in features:
    groups = [agg_df[agg_df['cluster'] == c][feat].values for c in sorted(agg_df['cluster'].unique())]
    f_stat, p_val = stats.f_oneway(*groups)
    eta = eta_squared(groups)

    sig = interpret_p(p_val)
    effect = interpret_eta(eta)

    print(f"  {feat:<12} {f_stat:>8.2f} {p_val:>10.4f} {sig:>5}  {eta:>6.4f}  {effect}")
    anova_results.append({
        '변수': feat, 'F값': round(f_stat, 2),
        'p값': round(p_val, 4), 'eta_squared': round(eta, 4), '효과크기': effect
    })

print()


